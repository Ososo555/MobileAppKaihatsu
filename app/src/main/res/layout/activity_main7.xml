<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity7">

    <TextView
        android:id="@+id/textViewPriority"
        android:layout_width="61dp"
        android:layout_height="34dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="50dp"
        android:text="優先"
        android:textSize="20dp"
        app:layout_constraintEnd_toStartOf="@+id/textViewTransport"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textViewTransport"
        android:layout_width="152dp"
        android:layout_height="34dp"
        android:layout_marginStart="30dp"
        android:text="WiFi"
        android:textSize="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/textViewPriority"
        app:layout_constraintTop_toTopOf="@id/textViewPriority" />

    <TextView
        android:id="@+id/textViewIPAddress"
        android:layout_width="131dp"
        android:layout_height="34dp"
        android:layout_marginTop="10dp"
        android:text="IPアドレス"
        android:textSize="17dp"
        app:layout_constraintStart_toStartOf="@+id/textViewPriority"
        app:layout_constraintTop_toBottomOf="@+id/textViewPriority" />

    <TextView
        android:id="@+id/inIPAddress"
        android:layout_width="131dp"
        android:layout_height="34dp"
        android:layout_marginTop="10dp"
        android:text="192168.0.1"
        android:textSize="17dp"
        app:layout_constraintStart_toStartOf="@+id/textViewPriority"
        app:layout_constraintTop_toBottomOf="@+id/textViewIPAddress" />

</androidx.constraintlayout.widget.ConstraintLayout>